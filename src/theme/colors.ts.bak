import { Platform } from "react-native";

// ─────────────────────────────────────────────
// PLATE PARTY — DESIGN TOKENS (Purple + White)
// ─────────────────────────────────────────────

const palette = {
  // Primary purple scale
  purple: {
    50:  "#F5F3FF",
    100: "#EDE9FE",
    200: "#DDD6FE",
    300: "#C4B5FD",
    400: "#A78BFA",
    500: "#8B5CF6",
    600: "#7C3AED",
    700: "#6D28D9",
    800: "#5B21B6",
    900: "#4C1D95",
    950: "#2E1065",
  },
  // Neutral gray scale
  gray: {
    0:   "#FFFFFF",
    50:  "#FCFAFF",
    100: "#F5F3F7",
    200: "#E5E1EB",
    300: "#D1CBD7",
    400: "#A89FB0",
    500: "#6B6478",
    600: "#504A5C",
    700: "#3A3544",
    800: "#252230",
    900: "#0F0C19",
    950: "#080610",
  },
  // Semantic colors
  success: "#10B981",
  error:   "#EF4444",
  warning: "#F59E0B",
  info:    "#3B82F6",
  // Charity accents
  plate:   "#F59E0B",
  impact:  "#34D399",
} as const;

// ── PRIMARY ──
export const primary = {
  base:     palette.purple[600],   // #7C3AED
  dark:     palette.purple[700],   // #6D28D9
  darker:   palette.purple[800],   // #5B21B6
  light:    palette.purple[100],   // #EDE9FE
  subtle:   palette.purple[200],   // #DDD6FE
  gradient: [palette.purple[600], palette.purple[700]] as const,
} as const;

// ── NEUTRAL ──
export const neutral = {
  0:   palette.gray[0],   // White
  50:  palette.gray[50],  // Surface
  100: palette.gray[100], // Card bg
  200: palette.gray[200],
  300: palette.gray[300],
  400: palette.gray[400],
  500: palette.gray[500], // Secondary text
  600: palette.gray[600],
  700: palette.gray[700],
  800: palette.gray[800],
  900: palette.gray[900], // Primary text
  950: palette.gray[950],
} as const;

// ── SEMANTIC ──
export const semantic = {
  success: palette.success,
  error:   palette.error,
  warning: palette.warning,
  info:    palette.info,
} as const;

// ── CHARITY ──
export const charity = {
  plate:  palette.plate,
  impact: palette.impact,
} as const;

