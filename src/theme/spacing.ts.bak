// ── SPACING SCALE (8px grid) ──
export const spacing = {
  0:   0,
  0.5: 2,   // 4px / 2
  1:   4,   // 0.5 × 8
  2:   8,   // 1 × 8
  3:   12,  // 1.5 × 8
  4:   16,  // 2 × 8
  5:   20,  // 2.5 × 8
  6:   24,  // 3 × 8
  7:   32,  // 4 × 8
  8:   40,  // 5 × 8
  9:   48,  // 6 × 8
  10:  64,  // 8 × 8
  11:  80,  // 10 × 8
  12:  96,  // 12 × 8
} as const;

export type Spacing = typeof spacing;
