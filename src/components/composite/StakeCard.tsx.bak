import React from "react";
import {
  View,
  Text,
  TouchableOpacity,
  StyleSheet,
} from "react-native";
import { useNavigation } from "@react-navigation/native";
import { colors, typography, spacing } from "../../theme";

interface StakeCardProps {
  stake: {
    id: string;
    title: string;
    creator: string;
    creatorName?: string;
    date: string;
    entries: number;
    totalPlates: number;
    plateReward: number;
  };
}

export default function StakeCard({ stake }: StakeCardProps) {
  const navigation = useNavigation();

  const handleAttempt = () => {
    (navigation as any).navigate("EnterStake", {
      stakeId: stake.id,
      title: stake.title,
      creator: stake.creatorName || stake.creator || "Anonymous",
    });
  };

  return (
    <View style={styles.card}>
      <View style={styles.header}>
        <View style={styles.avatar}>
          <Text style={styles.avatarText}>
            {(stake.creatorName || stake.creator || "?").charAt(0).toUpperCase()}
          </Text>
        </View>
        <View style={styles.meta}>
          <Text style={styles.creator}>{stake.creatorName || stake.creator}</Text>
          <Text style={styles.date}>{stake.date}</Text>
        </View>
        <View style={styles.rewardBadge}>
          <Text style={styles.rewardText}>🍽 {stake.plateReward}</Text>
        </View>
      </View>

      <Text style={styles.title}>{stake.title}</Text>

      <View style={styles.footer}>
        <Text style={styles.footerText}>
          {stake.entries} {stake.entries === 1 ? "entry" : "entries"}
        </Text>
        <Text style={styles.footerText}>{stake.totalPlates} plates total</Text>
        <TouchableOpacity style={styles.attemptBtn} onPress={handleAttempt}>
          <Text style={styles.attemptText}>Attempt</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  card: {
    backgroundColor: colors.neutral[0],
    borderRadius: 16,
    padding: spacing[4],
    marginBottom: spacing[3],
    shadowColor: colors.neutral[900],
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.06,
    shadowRadius: 8,
    elevation: 3,
  },
  header: {
    flexDirection: "row",
    alignItems: "center",
    marginBottom: spacing[3],
  },
  avatar: {
    width: 36,
    height: 36,
    borderRadius: 18,
    backgroundColor: colors.primary.light,
    alignItems: "center",
    justifyContent: "center",
  },
  avatarText: {
    fontSize: typography.sizes.base,
    fontWeight: typography.weights.bold,
    color: colors.primary.base,
  },
  meta: {
    flex: 1,
    marginLeft: spacing[3],
  },
  creator: {
    fontSize: typography.sizes.base,
    fontWeight: typography.weights.semibold,
    color: colors.neutral[900],
  },
  date: {
    fontSize: typography.sizes.sm,
    color: colors.neutral[500],
  },
  rewardBadge: {
    backgroundColor: colors.semantic.successBg,
    paddingHorizontal: spacing[2],
    paddingVertical: spacing[1],
    borderRadius: 8,
  },
  rewardText: {
    fontSize: typography.sizes.sm,
    fontWeight: typography.weights.semibold,
    color: colors.semantic.success,
  },
  title: {
    fontSize: typography.sizes.lg,
    fontWeight: typography.weights.bold,
    color: colors.neutral[900],
    marginBottom: spacing[3],
  },
  footer: {
    flexDirection: "row",
    alignItems: "center",
    justifyContent: "space-between",
  },
  footerText: {
    fontSize: typography.sizes.sm,
    color: colors.neutral[500],
  },
  attemptBtn: {
    backgroundColor: colors.semantic.success,
    paddingHorizontal: spacing[4],
    paddingVertical: spacing[2],
    borderRadius: 10,
  },
  attemptText: {
    fontSize: typography.sizes.base,
    fontWeight: typography.weights.bold,
    color: colors.neutral[0],
  },
});
